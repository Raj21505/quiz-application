# Copy this file to docker/.env and set real values before deploying.

POSTGRES_USER=quiz_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=quiz_db
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=8501

# Public URL for backend docs/logging (used by FastAPI startup logs)
PUBLIC_BASE_URL=http://localhost:8000

# Frontend talks to backend from inside docker network
API_BASE=http://backend:8000

# Firebase config
FIREBASE_DB_URL=https://your-project-default-rtdb.firebaseio.com/
FIREBASE_WEB_API_KEY=replace_with_web_api_key

# Admin login for Streamlit admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password

# Option A: host credentials file mounted into backend container (recommended)
FIREBASE_CREDENTIALS_HOST_PATH=../secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase_credentials.json

# Option B: inline JSON credentials in one line (leave blank when using Option A)
FIREBASE_CREDENTIALS_JSON=
